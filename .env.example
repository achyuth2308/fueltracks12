# ============================================================
# FuelTracks — Environment Variables Reference
# Copy this to .env and fill in for your environment.
# ============================================================

# ---- Node / app ----
NODE_ENV=development

# ---- API server ----
API_PORT=3001

# ---- TCP ingestion ports (one per protocol) ----
TCP_PORT=5000           # BSTPL-17
AIS140_TCP_PORT=5001    # AIS140 / tNavIC
CONCOX_TCP_PORT=5002    # Concox V5/VL149/GT800 (binary)
TCP_HEALTH_PORT=5050    # TCP server /health and /metrics

# ---- PostgreSQL ----
# Local dev (docker compose): 127.0.0.1
# Production (same EC2):      127.0.0.1
# Production (RDS):           your-rds-endpoint.region.rds.amazonaws.com
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=fueltracks
DB_USER=postgres
DB_PASS=postgres

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ---- JWT ----
# MUST be changed in production. The server refuses to start
# in production if this is left as the default.
JWT_SECRET=change_me_in_production_min_64_random_chars
JWT_EXPIRES_IN=24h

# ---- CORS ----
# Production: set to your frontend origin, e.g.
#   https://app.fueltracks.in
# Dev: '*' is fine but logs a warning on backend startup.
CORS_ORIGIN=*

# ============================================================
# Scaling tunables (Phase 1-7 of SCALING_ROADMAP.md)
# All have safe defaults. Override only if you have evidence
# the default is wrong for your load profile.
# ============================================================

# TCP backpressure
TCP_HIGH_WATER=50
TCP_LOW_WATER=10

# Connection caps (per-port global + per-IMEI)
TCP_PORT_CAP_BSTPL=12000
TCP_PORT_CAP_AIS140=10000
TCP_PORT_CAP_CONCOX=8000
TCP_PER_IMEI_CAP=3

# Redis Streams
STREAM_MAXLEN=1000000
STREAM_BATCH_SIZE=200
STREAM_BLOCK_MS=1000

# Writer batch sizing
WRITER_BATCH_ROWS=1000
WRITER_BATCH_MS=1000
WRITER_METRICS_PORT=5060

# Raw packet sampling (1-in-N; set 1 to disable)
RAW_LOG_SAMPLE_RATE=100

# Postgres pool per process
PG_POOL_MAX=50
PG_STATEMENT_TIMEOUT_MS=30000

# Consumer-group names (only change if you have a multi-tenancy
# reason; defaults are correct for single-cluster deployments)
STREAM_GROUP=fueltracks_broadcaster
WRITER_GROUP=fueltracks_writer
ALERT_STREAM_GROUP=fueltracks_alert_writer

# GPS-no-fix detector (run as cron)
NO_FIX_HOURS=1
