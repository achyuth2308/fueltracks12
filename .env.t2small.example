# ============================================================
# FuelTracks — t2.small tuned config (free-tier safe)
# COPY THIS TO .env IF YOU'RE ON t2.small OR t3.small
# ============================================================
# These overrides push the realistic device ceiling as high as
# possible given the 1 vCPU / 2 GB RAM constraint. Do NOT use
# this on larger instances — the defaults in .env.example are
# tuned for 4+ vCPU / 8+ GB.

NODE_ENV=production

# App ports (unchanged)
API_PORT=3001
TCP_PORT=5000
AIS140_TCP_PORT=5001
CONCOX_TCP_PORT=5002
TCP_HEALTH_PORT=5050

# DB / Redis on localhost (same EC2)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=fueltracks
DB_USER=postgres
DB_PASS=postgres

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT — change this!
JWT_SECRET=change_me_in_production_min_64_random_chars
JWT_EXPIRES_IN=24h

# CORS — set your frontend origin in production
CORS_ORIGIN=*

# ============================================================
# t2.small scaling overrides — conservative
# ============================================================

# TCP backpressure — LOWER so we pause sooner (less memory)
TCP_HIGH_WATER=20
TCP_LOW_WATER=5

# Connection caps — lower (less RAM)
TCP_PORT_CAP_BSTPL=400
TCP_PORT_CAP_AIS140=300
TCP_PORT_CAP_CONCOX=300
TCP_PER_IMEI_CAP=3

# Streams — smaller batches (less peak RAM)
STREAM_MAXLEN=200000
STREAM_BATCH_SIZE=100
STREAM_BLOCK_MS=1000

# Writer — smaller batches, faster flush (less in-memory buffer)
WRITER_BATCH_ROWS=200
WRITER_BATCH_MS=500
WRITER_METRICS_PORT=5060

# Raw packet sampling — keep at 100 (don't disable — would blow RAM)
RAW_LOG_SAMPLE_RATE=100

# Postgres pool — REDUCE hard. t2.small can't actually serve 50.
# 5 per process × 4 processes = 20, well under max_connections=100
PG_POOL_MAX=10
PG_STATEMENT_TIMEOUT_MS=15000

# Consumer groups (defaults)
STREAM_GROUP=fueltracks_broadcaster
WRITER_GROUP=fueltracks_writer
ALERT_STREAM_GROUP=fueltracks_alert_writer

# GPS-no-fix detector
NO_FIX_HOURS=1
